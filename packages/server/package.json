{
  "name": "@devpulse/server",
  "version": "0.1.0",
  "private": true,
  "description": "DevPulse API backend",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "migrate": "node-pg-migrate"
  },
  "dependencies": {
    "@devpulse/core": "workspace:*",
    "@devpulse/connectors": "workspace:*",
    "express": "^5.2.1",
    "pg": "^8.12.0",
    "bullmq": "^5.70.1",
    "ioredis": "^5.4.0",
    "node-pg-migrate": "^8.0.4",
    "cors": "^2.8.5",
    "helmet": "^8.1.0",
    "express-rate-limit": "^8.2.1",
    "js-yaml": "^4.1.0",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/pg": "^8.11.0",
    "@types/cors": "^2.8.17",
    "@types/js-yaml": "^4.0.9",
    "jest": "^29.7.0",
    "@types/jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "tsx": "^4.11.0"
  }
}
